"Composing objects"
object Counter {
    | count |
    init  [ count := 0 ]
    inc   [ count := count + 1. ^self ]
    value [ ^count ]
}

object LoggedCounter {
    compose Counter.
    inc [ super inc. Console println: 'incremented'. ^self ]
}

| c |
c := LoggedCounter new.
c inc; inc; inc.
Console println: c value printString.   "=> 3"