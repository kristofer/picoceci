" Math module - mathematical utility functions "

| Math: Any |

Math := [
	| factorial: Any  fibonacci: Any |

	factorial := [ :n |
		n <= 1 ifTrue: [ 1 ] ifFalse: [ n * (factorial value: n - 1) ]
	].

	fibonacci := [ :n |
		n <= 1 ifTrue: [ n ] ifFalse: [
			(fibonacci value: n - 1) + (fibonacci value: n - 2)
		]
	].
].
