"Factorial — recursive using a recursive block"
| fact: Any |
fact := [ :n |
    (n <= 1)
        ifTrue:  [ 1 ]
        ifFalse: [ n * (fact value: n - 1) ]
].
Transcript println: (fact value: 16) printString.

Transcript println: (fact value: 0) printString.
Transcript println: (fact value: 5) printString.
Transcript println: (fact value: 10) printString.
"Expected:
1
120
3628800"
