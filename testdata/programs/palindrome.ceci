"Palindrome check — tests if a string reads the same forwards and backwards"
| isPalindrome |
isPalindrome := [ :s | s = s reversed ].
Console println: (isPalindrome value: 'racecar') printString.
Console println: (isPalindrome value: 'hello') printString.
Console println: (isPalindrome value: 'level') printString.
Console println: (isPalindrome value: 'madam') printString.
"Expected:
true
false
true
true"
