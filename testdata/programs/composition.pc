"Composition — LoggedCounter composes Counter and overrides inc"
object Counter {
    | count: Int |
    init  [ count := 0 ]
    inc   [ count := count + 1. ^self ]
    value [ ^count ]
}
| c: Counter|
c := Counter new.
c inc.
c inc.
Transcript println: c value printString.

object LoggedCounter {
    compose Counter.
    inc [
        "call the composed Counter's inc via method body sharing"
        count := count + 1.
        Console println: 'incremented to ', count printString.
        ^self
    ]
}

| c: LoggedCounter |
c := LoggedCounter new.
c inc.
c inc.
Console println: c value printString.
"Expected: 2"
